network publica (outbound = 'yes')

system node (
cpu.arch='x86_64' and
cpu.count>=1 and
memory.size>=1g and
net_interface.0.connection = 'publica' and
disk.0.os.name='linux' and
disk.0.image.url = 'one://ramses.i3m.upv.es/1593'
)

configure node (
@begin
---
 - tasks:
     - fail: msg="Incorrect Ansible Version. Expected 2.19.8 but found {{  ansible_version.string }}"
       when: ansible_version.string != "2.19.8"

@end
)

contextualize (
  option ansible_version = '12.3.0'
  system node configure node
)

deploy node 1
