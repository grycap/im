network publica (outbound = 'yes')
network privada ()

system im (
cpu.count>=4 and
memory.size>=8G and
net_interface.0.connection = 'publica' and
net_interface.1.connection = 'privada' and
net_interface.1.dns_name = 'imservice' and
disk.0.os.name='linux' and
disk.0.os.flavour='ubuntu' and
disk.0.os.version >= '24.04' and
disk.0.applications contains (name='ansible.roles.grycap.docker')
)

system imclient (
cpu.count>=2 and
memory.size>=2G and
net_interface.0.connection = 'privada' and
net_interface.0.dns_name = 'imclient' and
disk.0.os.name='linux' and
disk.0.os.flavour='ubuntu' and
disk.0.os.version >= '24.04' and
disk.0.os.credentials.new.password = 'Tututu+01'
)

system infra (
cpu.count>=4 and
memory.size>=8G and
net_interface.0.connection = 'privada' and
net_interface.0.dns_name = 'infra' and
disk.0.os.name='linux' and
disk.0.os.flavour='ubuntu' and
disk.0.os.version >= '24.04' and
disk.0.size >= 50g and
disk.0.applications contains (name='ansible.roles.grycap.nfs') and
disk.0.applications contains (name='ansible.roles.grycap.kubernetes')
)

system infrawn (
cpu.count>=4 and
memory.size>=8G and
net_interface.0.connection = 'privada' and
net_interface.0.dns_name = 'infrawn-#N#' and
disk.0.os.name='linux' and
disk.0.os.flavour='ubuntu' and
disk.0.os.version >= '24.04' and
disk.0.applications contains (name='ansible.roles.grycap.kubernetes')
)


configure im (
@begin
---
  - vars:
     IMVERSION: devel

    roles:
    - role: 'grycap.docker'

    tasks:
    - name: Create IM directory
      file:
        path: /opt/im
        state: directory
        mode: '755'

    - copy:
        dest: /opt/im/docker-compose.yaml
        mode: '755'
        content: |
            version: "3.8"
            services:
              mongodb:
                image: mongo:7
                container_name: im-mongodb
                restart: always
                environment:
                  MONGO_INITDB_ROOT_USERNAME: im
                  MONGO_INITDB_ROOT_PASSWORD: im_password
                  MONGO_INITDB_DATABASE: im
                volumes:
                  - ./mongodb_data:/data/db
                ports:
                  - "27017:27017"
              im:
                image: ghcr.io/grycap/im:{{ IMVERSION }}
                container_name: im-service
                depends_on:
                  - mongodb
                restart: always
                ports:
                  - "8800:8800"
                environment:
                  IM_DATA_DB: "mongodb://im:im_password@mongodb:27017/im?authSource=admin"
                volumes:
                  - ./im_log:/var/log/im

    - name: Launch IM
      community.docker.docker_compose_v2:
        project_src: /opt/im/
        state: present

    - name: Install Reqs Deb
      apt: name=sysstat update_cache=yes cache_valid_time=3600
      when: ansible_os_family == "Debian"
      
    - name: Install Reqs RH
      yum: name=sysstat
      when: ansible_os_family == "RedHat"

    - name: Configure sysstat
      lineinfile: dest=/etc/default/sysstat regexp="^ENABLED=" line='ENABLED="true"'
      when: ansible_os_family == "Debian"

    - name: Configure cron sysstat
      #copy: dest=/etc/cron.d/sysstat content="*/1 * * * * root date >> /tmp/dates && /usr/lib/sysstat/debian-sa1 1 1\n"
      copy: dest=/etc/cron.d/sysstat content="*/1 * * * * root command -v /usr/lib/sysstat/debian-sa1 > /dev/null && /usr/lib/sysstat/debian-sa1 1 1\n"
      when: ansible_os_family == "Debian"

    - name: Configure sysstat
      ini_file:
        path: /lib/systemd/system/sysstat-collect.timer
        section: Timer
        option: OnCalendar
        value: "*:00/1"

    - name: Reload systemd
      systemd_service:
        daemon_reload: true

    - name: Restart sysstat
      service: name=sysstat state=restarted
      
    - name: Start sysstat
      shell: /usr/lib/sysstat/debian-sa1 1 1
      when: ansible_os_family == "Debian"
@end
)

configure imclient (
@begin
---
  - vars:
      INFRA_NODE_IP: "{{ hostvars[groups['infra'][0]]['IM_NODE_NET_0_IP'] }}"
      DURATION: 300
      THREADS_READ: 10
      THREADS_WRITE: 5
      RAND_DELAY: 10
      CONST_DELAY: 10
    tasks:
    - name: Install Reqs
      apt: name=openjdk-8-jdk update_cache=yes cache_valid_time=3600

    - name: Download apache-jmeter-5.1.1.tgz
      get_url: url=http://ftpgrycap.i3m.upv.es/src/apache-jmeter-5.1.1.tgz dest=/opt/apache-jmeter-5.1.1.tgz
      
    - name: Extract apache-jmeter in /opt
      unarchive:
        src: /opt/apache-jmeter-5.1.1.tgz
        dest: /opt/
        creates: /opt/apache-jmeter-5.1.1
        remote_src: yes

    - name: Create test.sh file
      copy:
        dest: /var/tmp/test.sh
        content: |
          #!/bin/bash 
          /opt/apache-jmeter-5.1.1/bin/jmeter -n -t /var/tmp/im_load_tests.jmx -JIMHOST=imservice -JKUBE_IP={{INFRA_NODE_IP}} -JTHREADS_READ={{ THREADS_READ }} -JTHREADS_WRITE={{ THREADS_WRITE }} -JDURATION={{ DURATION }} -JCONST_DELAY={{ CONST_DELAY }} -JRAND_DELAY={{ RAND_DELAY }}          
        mode: 0755

    - name: Download LoadTest files
      get_url:
        url: "https://github.com/grycap/im/raw/refs/heads/master/test/loadtest/im_load_tests.jmx"
        dest: /var/tmp/im_load_tests.jmx

@end
)

configure infrawn (
@begin
  - roles:
    - role: 'grycap.nfs'
      nfs_mode: 'wn'

    - role: 'grycap.kubernetes'
      kube_type_of_node: 'wn'
      kube_server: 'infra'
      kube_version: 1.33.2
@end
)

configure infra (
@begin
  - vars:
      KUBEVIRT_VERSION: 'v1.8.2'
      CDI_VERSION: 'v1.65.0'
    pre_tasks:
    - firewalld: port=6443/tcp permanent=true state=enabled immediate=yes
      when: ansible_os_family == "RedHat"
      ignore_errors: yes

    - name: Create dir for the NFS PV
      file: path=/pv state=directory mode=755
    - name: Create auth file dir
      file: path=/etc/kubernetes/pki state=directory mode=755 recurse=yes
    - name: Create auth data file with an admin user
      copy: content='sometoken,kubeuser,100,"users,system:masters"' dest=/etc/kubernetes/pki/auth mode=600

    roles:
    - role: 'grycap.nfs'
      nfs_mode: 'front'
      nfs_exports: [{path: "/pv", export: "*.localdomain(fsid=0,rw,async,no_root_squash,no_subtree_check,insecure)"}]

    - role: 'grycap.kubernetes'
      kube_server: 'infra'
      kube_apiserver_options:
        - option: "--token-auth-file"
          value: "/etc/kubernetes/pki/auth"
      kube_deploy_dashboard: false
      kube_install_helm: false
      kube_version: 1.33.2
      kube_install_nfs_client: true
      kube_nfs_server: 'infra.localdomain'

    tasks:
    - name: Install KubeVirt
      command: kubectl apply -f {{ item }}
      environment:
        KUBECONFIG: "/etc/kubernetes/admin.conf"
      with_items:
        - https://github.com/kubevirt/kubevirt/releases/download/{{ KUBEVIRT_VERSION }}/kubevirt-operator.yaml
        - https://github.com/kubevirt/kubevirt/releases/download/{{ KUBEVIRT_VERSION }}/kubevirt-cr.yaml

    - name: Wait for KubeVirt to be available
      command: kubectl -n kubevirt wait kv kubevirt --for condition=Available  --timeout=600s
      environment:
        KUBECONFIG: "/etc/kubernetes/admin.conf"

    - name: Install CDI
      command: kubectl apply -f {{ item }}
      environment:
        KUBECONFIG: "/etc/kubernetes/admin.conf"
      with_items:
        - https://github.com/kubevirt/containerized-data-importer/releases/download/{{ CDI_VERSION }}/cdi-operator.yaml
        - https://github.com/kubevirt/containerized-data-importer/releases/download/{{ CDI_VERSION }}/cdi-cr.yaml

    - name: Wait for CDI to be available
      command: kubectl wait cdi cdi --for=condition=Available --timeout=600s
      environment:
        KUBECONFIG: "/etc/kubernetes/admin.conf"

    - name: Create StorageProfile file
      copy:
        content: |
          apiVersion: cdi.kubevirt.io/v1beta1
          kind: StorageProfile
          metadata:
            name: local-path
          spec:
            claimPropertySets:
              - accessModes:
                  - ReadWriteMany
                volumeMode: Filesystem
        dest: "/var/tmp/storage_profile.yaml"
        mode: '644'
      register: storage_profile

    - name: Create StorageProfile for Local path
      command: kubectl apply -f /var/tmp/storage_profile.yaml
      environment:
        KUBECONFIG: "/etc/kubernetes/admin.conf"
      when: storage_profile is changed
@end
)



deploy im 1
deploy imclient 1
deploy infra 1
deploy infrawn 2
